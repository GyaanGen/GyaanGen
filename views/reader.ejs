<!DOCTYPE html>
<html>
<head>
    <title>Reader</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body {
            margin: 0;
            background: #0f172a;
            color: white;
            font-family: Arial;
        }

        .container {
            display: flex;
            height: 100vh;
            flex-direction: row;
        }

        iframe {
            width: 70%;
            border: 2px solid #38bdf8;
            border-radius: 12px;
            margin: 15px;
            background: #020617;
            box-shadow:
                0 0 10px rgba(56, 189, 248, 0.4),
                0 0 20px rgba(56, 189, 248, 0.2);
            transition: 0.3s;
        }

        .notes {
            width: 30%;
            padding: 20px;
            background: #1e293b;
            display: flex;
            flex-direction: column;
        }

        /* ── Mobile: stack vertically with tabs ── */
        @media (max-width: 768px) {

            .container {
                flex-direction: column;
                height: calc(100vh - 45px); /* subtract tab bar height */
            }

            .mobile-tabs {
                display: flex;
                background: #0f172a;
                border-bottom: 1px solid #334155;
            }

            .mobile-tab {
                flex: 1;
                padding: 12px;
                text-align: center;
                font-size: 13px;
                cursor: pointer;
                color: #64748b;
                border-bottom: 2px solid transparent;
                transition: 0.2s;
            }

            .mobile-tab.active {
                color: #38bdf8;
                border-bottom-color: #38bdf8;
            }

            iframe {
                width: calc(100% - 20px);
                margin: 10px;
                flex: 1;
                min-height: 0;
            }

            .notes {
                width: 100%;
                flex: 1;
                min-height: 0;
            }

            .hidden-mobile { display: none !important; }
        }

        /* Desktop: hide tab switcher */
        @media (min-width: 769px) {
            .mobile-tabs { display: none; }
        }

        .notes h3 {
            margin-bottom: 12px;
            color: #38bdf8;
        }

        textarea {
            flex: 1;
            resize: none;
            padding: 10px;
            background: #0f172a;
            color: white;
            border: 1px solid #334155;
            border-radius: 8px;
            font-size: 14px;
            line-height: 1.6;
        }

        textarea:focus {
            outline: none;
            border-color: #38bdf8;
        }

        button {
            margin-top: 10px;
            padding: 10px;
            background: #38bdf8;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            color: #0f172a;
            transition: 0.2s;
        }

        button:hover { background: #0ea5e9; }

        #status {
            margin-top: 8px;
            font-size: 13px;
            color: #38bdf8;
            text-align: center;
            min-height: 18px;
        }
    </style>
</head>
<body>

<!-- Mobile tab bar (hidden on desktop via CSS) -->
<div class="mobile-tabs">
    <div class="mobile-tab active" id="tab-pdf" onclick="switchMobileTab('pdf')">📄 PDF</div>
    <div class="mobile-tab" id="tab-notes" onclick="switchMobileTab('notes')">📝 Notes</div>
</div>

<div class="container">

    <iframe id="pdfFrame" src="<%= pdf %>"></iframe>

    <div class="notes" id="notesPanel">
        <h3>📝 My Notes</h3>
        <textarea id="noteInput" placeholder="Write your notes here..."></textarea>
        <button onclick="saveNote()">Save Notes</button>
        <div id="status"></div>
    </div>

</div>

<script>
    const pdfUrl = "<%= pdf %>";

    // ── Mobile tab switching ──
    function switchMobileTab(tab) {
        const pdf   = document.getElementById('pdfFrame');
        const notes = document.getElementById('notesPanel');
        const isMobile = window.innerWidth <= 768;

        if (!isMobile) return;

        if (tab === 'pdf') {
            pdf.classList.remove('hidden-mobile');
            notes.classList.add('hidden-mobile');
        } else {
            pdf.classList.add('hidden-mobile');
            notes.classList.remove('hidden-mobile');
        }

        document.getElementById('tab-pdf').classList.toggle('active', tab === 'pdf');
        document.getElementById('tab-notes').classList.toggle('active', tab === 'notes');
    }

    // On load — hide notes panel on mobile by default, show PDF
    if (window.innerWidth <= 768) {
        document.getElementById('notesPanel').classList.add('hidden-mobile');
    }

    // ── Load saved note from DB on page open ──
    async function loadNote() {
        try {
            const res = await fetch(`/home/reader/notes?pdfUrl=${encodeURIComponent(pdfUrl)}`);
            const data = await res.json();
            document.getElementById("noteInput").value = data.text;
        } catch (err) {
            console.log("Could not load notes", err);
        }
    }

    // ── Save note to DB ──
    async function saveNote() {
        const text = document.getElementById("noteInput").value.trim();

        try {
            const res = await fetch("/home/reader/notes", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ pdfUrl, text })
            });

            const data = await res.json();

            if (data.success) {
                document.getElementById("status").innerText = "✓ Notes Saved";
                setTimeout(() => {
                    document.getElementById("status").innerText = "";
                }, 2000);
            }

        } catch (err) {
            console.log("Could not save notes", err);
            document.getElementById("status").innerText = "❌ Save failed";
        }
    }

    // Load note when page opens
    loadNote();
</script>

</body>
</html>
