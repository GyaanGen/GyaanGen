<!DOCTYPE html>
<html lang="en">
<head>
    <title>Practice Quiz | GyaanGen</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #0f172a;
            color: #f1f5f9;
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
        }

        /* ── Loader ── */
        #loader {
            position: fixed;
            inset: 0;
            background: #0f172a;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 20px;
        }

        .spinner {
            width: 48px;
            height: 48px;
            border: 3px solid #1e293b;
            border-top-color: #38bdf8;
            border-radius: 50%;
            animation: spin 0.9s linear infinite;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        .loader-text {
            font-size: 14px;
            color: #64748b;
        }

        /* ── Top nav ── */
        .topnav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 24px;
            background: #0d1117;
            border-bottom: 1px solid #1e293b;
        }

        .logo {
            font-size: 18px;
            font-weight: 600;
            color: #38bdf8;
        }

        .back-btn {
            padding: 8px 16px;
            border: 1px solid #1e293b;
            border-radius: 8px;
            background: transparent;
            color: #94a3b8;
            font-family: 'Poppins', sans-serif;
            font-size: 13px;
            cursor: pointer;
            transition: 0.2s;
        }

        .back-btn:hover { border-color: #38bdf8; color: #38bdf8; }

        /* ── Tab bar ── */
        .tabbar {
            display: flex;
            padding: 0 24px;
            background: #0d1117;
            border-bottom: 1px solid #1e293b;
            overflow-x: auto;
        }

        .tab-btn {
            padding: 14px 20px;
            border: none;
            border-bottom: 2px solid transparent;
            background: transparent;
            color: #64748b;
            font-family: 'Poppins', sans-serif;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .tab-btn:hover { color: #f1f5f9; }

        .tab-btn.active {
            color: #f1f5f9;
            border-bottom-color: #38bdf8;
        }

        .pill {
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 99px;
            font-weight: 600;
        }

        .pill-mcq   { background: rgba(56,189,248,0.15);  color: #38bdf8; }
        .pill-short { background: rgba(129,140,248,0.15); color: #818cf8; }
        .pill-long  { background: rgba(52,211,153,0.15);  color: #34d399; }
        .pill-disc  { background: rgba(251,146,60,0.15);  color: #fb923c; }

        /* ── Panels ── */
        .panel { display: none; padding: 24px; }
        .panel.active { display: block; }

        /* ── MCQ ── */
        .mcq-wrap { max-width: 680px; margin: 0 auto; }

        .progress-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            font-size: 13px;
            color: #64748b;
        }

        .progress-track {
            flex: 1;
            height: 4px;
            background: #1e293b;
            border-radius: 99px;
            margin: 0 14px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: #38bdf8;
            border-radius: 99px;
            transition: width 0.4s ease;
        }

        .mcq-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 12px;
            padding: 28px;
        }

        .q-label {
            font-size: 11px;
            color: #38bdf8;
            font-weight: 600;
            letter-spacing: 0.08em;
            margin-bottom: 10px;
        }

        .q-text {
            font-size: 17px;
            font-weight: 500;
            line-height: 1.6;
            margin-bottom: 24px;
        }

        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .option {
            padding: 12px 16px;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-family: 'Poppins', sans-serif;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: 0.2s;
            text-align: left;
            color: #f1f5f9;
        }

        .option:hover:not(.locked) {
            border-color: #38bdf8;
            background: rgba(56,189,248,0.05);
        }

        .option-letter {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #334155;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 600;
            flex-shrink: 0;
            transition: 0.2s;
        }

        .option.correct { border-color: #16a34a; background: rgba(22,163,74,0.1); }
        .option.correct .option-letter { background: #16a34a; color: white; }

        .option.wrong { border-color: #dc2626; background: rgba(220,38,38,0.1); }
        .option.wrong .option-letter { background: #dc2626; color: white; }

        .option.locked { cursor: default; }

        .result-msg {
            margin-top: 16px;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            display: none;
        }

        .result-msg.show { display: block; }
        .result-msg.correct { background: rgba(22,163,74,0.1); color: #4ade80; border: 1px solid rgba(22,163,74,0.3); }
        .result-msg.wrong   { background: rgba(220,38,38,0.1);  color: #f87171; border: 1px solid rgba(220,38,38,0.3); }

        .next-btn {
            display: none;
            width: 100%;
            margin-top: 16px;
            padding: 12px;
            background: #38bdf8;
            border: none;
            border-radius: 8px;
            color: #0f172a;
            font-family: 'Poppins', sans-serif;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .next-btn.show { display: block; }
        .next-btn:hover { background: #0ea5e9; }

        /* ── Score card ── */
        .score-card {
            max-width: 420px;
            margin: 0 auto;
            text-align: center;
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 40px 28px;
        }

        .score-emoji { font-size: 52px; margin-bottom: 14px; }

        .score-number {
            font-size: 44px;
            font-weight: 700;
            color: #38bdf8;
            margin-bottom: 6px;
        }

        .score-msg { font-size: 14px; color: #64748b; margin-bottom: 24px; }

        .retry-btn {
            padding: 10px 28px;
            background: transparent;
            border: 1px solid #38bdf8;
            border-radius: 8px;
            color: #38bdf8;
            font-family: 'Poppins', sans-serif;
            font-size: 14px;
            cursor: pointer;
            transition: 0.2s;
        }

        .retry-btn:hover { background: rgba(56,189,248,0.1); }

        /* ── Written sections ── */
        .section-header {
            max-width: 680px;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-icon {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .icon-short { background: rgba(129,140,248,0.15); }
        .icon-long  { background: rgba(52,211,153,0.15);  }
        .icon-disc  { background: rgba(251,146,60,0.15);  }

        .section-title { font-size: 18px; font-weight: 600; }
        .section-sub   { font-size: 12px; color: #64748b; margin-top: 2px; }

        .written-list {
            max-width: 680px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .written-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 10px;
            padding: 20px 24px;
            display: flex;
            flex-direction: column;
        }

        .written-card-top {
            display: flex;
            gap: 16px;
            align-items: flex-start;
        }

        .q-num {
            font-size: 13px;
            font-weight: 700;
            min-width: 30px;
            padding-top: 2px;
        }

        .short-num { color: #818cf8; }
        .long-num  { color: #34d399; }
        .disc-num  { color: #fb923c; }

        /* ── Answer reveal ── */
        .answer-toggle {
            margin-top: 14px;
            padding: 6px 14px;
            background: transparent;
            border: 1px solid #334155;
            border-radius: 6px;
            color: #64748b;
            font-family: 'Poppins', sans-serif;
            font-size: 12px;
            cursor: pointer;
            transition: 0.2s;
            align-self: flex-start;
        }

        .answer-toggle:hover { border-color: #818cf8; color: #818cf8; }

        .answer-box {
            display: none;
            margin-top: 12px;
            padding: 14px 16px;
            border-radius: 8px;
            font-size: 14px;
            line-height: 1.7;
        }

        .answer-box.show { display: block; }

        .answer-box.short-ans  { background: rgba(129,140,248,0.07); border: 1px solid rgba(129,140,248,0.2); color: #c7d2fe; }
        .answer-box.long-ans   { background: rgba(52,211,153,0.07);  border: 1px solid rgba(52,211,153,0.2);  color: #a7f3d0; }
        .answer-box.disc-hints { background: rgba(251,146,60,0.07);  border: 1px solid rgba(251,146,60,0.2);  color: #fed7aa; }

        .ans-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            margin-bottom: 8px;
            opacity: 0.7;
        }

        .hint-item { display: flex; gap: 8px; margin-bottom: 6px; align-items: flex-start; }
        .hint-dot  { width: 5px; height: 5px; border-radius: 50%; background: #fb923c; flex-shrink: 0; margin-top: 8px; }

        /* ── Mobile ── */
        @media (max-width: 600px) {
            .options-grid { grid-template-columns: 1fr; }
            .panel { padding: 16px; }
            .topnav { padding: 12px 16px; }
        }
    </style>
</head>
<body>

<!-- Loader -->
<div id="loader">
    <div class="spinner"></div>
    <p class="loader-text">Generating questions with AI...</p>
</div>

<!-- Main content (hidden until questions load) -->
<div id="mainContent" style="display:none;">

    <nav class="topnav">
        <span class="logo">GyaanGen</span>
        <button class="back-btn" onclick="history.back()">← Back</button>
    </nav>

    <div class="tabbar">
        <button class="tab-btn active" onclick="switchTab('mcq', this)">
            ⚡ MCQs <span class="pill pill-mcq" id="mcqPill">10</span>
        </button>
        <button class="tab-btn" onclick="switchTab('short', this)">
            ✏️ Short Answer <span class="pill pill-short" id="shortPill">10</span>
        </button>
        <button class="tab-btn" onclick="switchTab('long', this)">
            📝 Long Answer <span class="pill pill-long" id="longPill">10</span>
        </button>
        <button class="tab-btn" onclick="switchTab('disc', this)">
            💬 Discussion <span class="pill pill-disc" id="discPill">2</span>
        </button>
    </div>

    <!-- MCQ Panel -->
    <div class="panel active" id="panel-mcq">
        <div class="mcq-wrap">
            <div class="progress-row">
                <span id="progressLabel">1 / 10</span>
                <div class="progress-track">
                    <div class="progress-fill" id="progressBar" style="width:10%"></div>
                </div>
                <span id="scoreLabel">Score: 0</span>
            </div>
            <div id="mcqContainer"></div>
        </div>
    </div>

    <!-- Short Answer Panel -->
    <div class="panel" id="panel-short">
        <div class="section-header">
            <div class="section-icon icon-short">✏️</div>
            <div>
                <div class="section-title">Short Answer Questions</div>
                <div class="section-sub">Write concise answers — 2 to 4 sentences each</div>
            </div>
        </div>
        <div class="written-list" id="shortContainer"></div>
    </div>

    <!-- Long Answer Panel -->
    <div class="panel" id="panel-long">
        <div class="section-header">
            <div class="section-icon icon-long">📝</div>
            <div>
                <div class="section-title">Long Answer Questions</div>
                <div class="section-sub">Detailed answers required — use examples and explanations</div>
            </div>
        </div>
        <div class="written-list" id="longContainer"></div>
    </div>

    <!-- Discussion Panel -->
    <div class="panel" id="panel-disc">
        <div class="section-header">
            <div class="section-icon icon-disc">💬</div>
            <div>
                <div class="section-title">Discussion Questions</div>
                <div class="section-sub">Think critically — there's no single right answer</div>
            </div>
        </div>
        <div class="written-list" id="discContainer"></div>
    </div>

</div>

<script>
    // ── Prevent back button bfcache ──
    window.addEventListener('pageshow', function(e) {
        if (e.persisted) window.location.reload();
    });

    const pdfUrl      = "<%= pdf %>";
    const subject     = "<%= subject %>";
    const chapterName = "<%= chapterName %>";

    let allMcqs      = [];
    let currentIndex = 0;
    let score        = 0;

    // ── Switch tabs ──
    function switchTab(name, el) {
        document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('panel-' + name).classList.add('active');
        el.classList.add('active');
    }

    // ── Render one MCQ ──
    function renderMCQ(index) {
        if (index >= allMcqs.length) { showScore(); return; }

        const q       = allMcqs[index];
        const letters = ['A', 'B', 'C', 'D'];
        const pct     = Math.round((index / allMcqs.length) * 100);

        document.getElementById('progressLabel').textContent = `${index + 1} / ${allMcqs.length}`;
        document.getElementById('progressBar').style.width   = `${pct}%`;
        document.getElementById('scoreLabel').textContent    = `Score: ${score}`;

        document.getElementById('mcqContainer').innerHTML = `
            <div class="mcq-card">
                <div class="q-label">QUESTION ${index + 1} OF ${allMcqs.length}</div>
                <div class="q-text">${q.question}</div>
                <div class="options-grid">
                    ${q.options.map((opt, i) => `
                        <button class="option" id="opt-${i}"
                            onclick="checkAnswer(${i}, '${opt.replace(/'/g,"\\'")}', '${q.answer.replace(/'/g,"\\'")}')">
                            <div class="option-letter">${letters[i]}</div>
                            <span>${opt}</span>
                        </button>
                    `).join('')}
                </div>
                <div class="result-msg" id="resultMsg"></div>
                <button class="next-btn" id="nextBtn" onclick="nextMCQ()">
                    ${index + 1 < allMcqs.length ? 'Next Question →' : 'See Results'}
                </button>
            </div>
        `;
    }

    function checkAnswer(selectedIdx, selected, correct) {
        const allOpts = document.querySelectorAll('.option');
        const msg     = document.getElementById('resultMsg');
        const nextBtn = document.getElementById('nextBtn');

        // lock all options and highlight correct
        allOpts.forEach(opt => {
            opt.classList.add('locked');
            opt.onclick = null;
            if (opt.querySelector('span').textContent.trim() === correct.trim()) {
                opt.classList.add('correct');
            }
        });

        const selectedText = allOpts[selectedIdx].querySelector('span').textContent.trim();

        if (selectedText === correct.trim()) {
            score++;
            msg.className = 'result-msg correct show';
            msg.textContent = '✅ Correct! Well done.';
        } else {
            allOpts[selectedIdx].classList.add('wrong');
            msg.className = 'result-msg wrong show';
            msg.innerHTML = `❌ Incorrect. Correct answer: <b>${correct}</b>`;
        }

        document.getElementById('scoreLabel').textContent = `Score: ${score}`;
        nextBtn.classList.add('show');
    }

    function nextMCQ() {
        currentIndex++;
        renderMCQ(currentIndex);
    }

    function showScore() {
        const pct   = Math.round((score / allMcqs.length) * 100);
        const emoji = pct >= 80 ? '🏆' : pct >= 60 ? '👍' : pct >= 40 ? '📚' : '😔';
        const msg   = pct >= 80 ? 'Excellent work!' : pct >= 60 ? 'Good job!' : pct >= 40 ? 'Keep studying!' : 'Keep practicing!';

        document.getElementById('progressBar').style.width         = '100%';
        document.getElementById('progressLabel').textContent       = 'Complete!';

        document.getElementById('mcqContainer').innerHTML = `
            <div class="score-card">
                <div class="score-emoji">${emoji}</div>
                <div class="score-number">${score}/${allMcqs.length}</div>
                <div class="score-msg">${msg} You scored ${pct}%</div>
                <button class="retry-btn" onclick="retryMCQ()">↺ Retry MCQs</button>
            </div>
        `;

        saveQuizResult(score, allMcqs.length, pct);
    }

    function retryMCQ() {
        currentIndex = 0;
        score        = 0;
        renderMCQ(0);
    }

    async function saveQuizResult(score, total, percentage) {
        try {
            await fetch("/practice/result", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ pdfUrl, subject, chapterName, score, total, percentage })
            });
        } catch (err) {
            console.log("Could not save quiz result", err);
        }
    }

    // ── Toggle answer reveal ──
    function toggleAnswer(btn) {
        const box    = btn.nextElementSibling;
        const isOpen = box.classList.toggle('show');
        const isDisc = box.classList.contains('disc-hints');
        btn.textContent = isOpen
            ? (isDisc ? 'Hide Key Points ▴' : 'Hide Answer ▴')
            : (isDisc ? 'Show Key Points ▾' : 'Show Answer ▾');
    }

    // ── Render written questions ──
    function renderWritten(list, containerId, numClass, type) {
        document.getElementById(containerId).innerHTML = list.map((q, i) => {

            let answerHTML = '';

            if (type === 'short') {
                answerHTML = `
                    <button class="answer-toggle" onclick="toggleAnswer(this)">Show Answer ▾</button>
                    <div class="answer-box short-ans">
                        <div class="ans-label">💡 Ideal Answer</div>
                        ${q.answer || 'Answer not available.'}
                    </div>`;
            }

            if (type === 'long') {
                answerHTML = `
                    <button class="answer-toggle" onclick="toggleAnswer(this)">Show Answer ▾</button>
                    <div class="answer-box long-ans">
                        <div class="ans-label">📖 Model Answer</div>
                        ${q.answer || 'Answer not available.'}
                    </div>`;
            }

            if (type === 'disc') {
                const hintsHTML = (q.hints || []).map(h => `
                    <div class="hint-item">
                        <div class="hint-dot"></div>
                        <span>${h}</span>
                    </div>`).join('');
                answerHTML = `
                    <button class="answer-toggle" onclick="toggleAnswer(this)">Show Key Points ▾</button>
                    <div class="answer-box disc-hints">
                        <div class="ans-label">🔑 Key Points to Discuss</div>
                        ${hintsHTML}
                    </div>`;
            }

            return `
                <div class="written-card">
                    <div class="written-card-top">
                        <div class="q-num ${numClass}">Q${i + 1}</div>
                        <div class="q-text">${q.question}</div>
                    </div>
                    ${answerHTML}
                </div>`;
        }).join('');
    }

// ── Fetch questions from backend ──
async function loadQuestions() {
    try {
        // 1. Fetch PDF in browser

        const pdfResponse = await fetch(pdfUrl);
        if (!pdfResponse.ok) throw new Error("Failed to fetch PDF");

        // 2. Convert to base64 in browser
        const arrayBuffer = await pdfResponse.arrayBuffer();
        const base64Data  = btoa(
            new Uint8Array(arrayBuffer).reduce((data, byte) => data + String.fromCharCode(byte), '')
        );

        document.getElementById('loader').querySelector('.loader-text').textContent
            = "Generating questions with AI...";

        // 3. Send base64 to backend
        const res  = await fetch('/practice/generate', {
            method: 'POST',                              // ← POST now
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ base64Data })         // ← send base64
        });

        const data = await res.json();

        if (!data.success) {
            document.getElementById('loader').innerHTML =
                `<p style="color:#f87171;font-size:14px;">❌ Failed to generate questions. Please go back and try again.</p>`;
            return;
        }

        const { mcqs, short_answers, long_answers, discussion_questions } = data.questions;
        allMcqs = mcqs;

        document.getElementById('mcqPill').textContent   = mcqs.length;
        document.getElementById('shortPill').textContent = short_answers.length;
        document.getElementById('longPill').textContent  = long_answers.length;
        document.getElementById('discPill').textContent  = discussion_questions.length;

        renderMCQ(0);
        renderWritten(short_answers,        'shortContainer', 'short-num', 'short');
        renderWritten(long_answers,         'longContainer',  'long-num',  'long');
        renderWritten(discussion_questions, 'discContainer',  'disc-num',  'disc');

        document.getElementById('loader').style.display      = 'none';
        document.getElementById('mainContent').style.display = 'block';

    } catch (err) {
        console.log('Error:', err);
        document.getElementById('loader').innerHTML =
            `<p style="color:#f87171;font-size:14px;">❌ Something went wrong. Please go back and try again.</p>`;
    }
}

    loadQuestions();
</script>

</body>
</html>
